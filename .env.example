# --- LLM (Claude — the brain's structured-output proposer) ---
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8

# --- CoinMarketCap (free tier — no Pro needed) ---
# Free Basic key from pro.coinmarketcap.com. MCP uses the first header form, REST the second.
CMC_API_KEY=
CMC_MCP_URL=https://mcp.coinmarketcap.com/mcp
CMC_REST_BASE=https://pro-api.coinmarketcap.com
CMC_X402_BASE=https://pro-api.coinmarketcap.com/x402

# --- Trust Wallet Agent Kit (execution + x402) ---
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=

# --- Signing keys: NONE here by design ---
# TWAK custodies the agent wallet key (OS keychain) and signs swaps + x402
# payments via the `twak` CLI — the agent never loads a raw private key.
# x402 settles on BNB Chain via TWAK's U/USDC route (not Base).

# --- BSC RPC (use a paid/keyed endpoint for the live week; public RPCs rate-limit) ---
BSC_RPC_URL=https://bsc-dataseed.binance.org
# Failover RPC — chain reads fall over here if the primary blips. Defaults to the
# public node; set a 2nd keyed RPC to keep getLogs/flow alive during a primary outage.
BSC_RPC_FALLBACK_URL=https://bsc-dataseed.binance.org
BSC_CHAIN_ID=56

# --- Ops ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Mode ---
# dev | live  (dev = mainnet-tiny amounts; TWAK testnet is undocumented)
PLIMSOLL_MODE=dev
