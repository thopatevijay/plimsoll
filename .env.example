# --- LLM (provider-agnostic; we use OpenAI) ---
LLM_PROVIDER=openai
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# --- CoinMarketCap (free tier — no Pro needed) ---
# Free Basic key from pro.coinmarketcap.com. MCP uses the first header form, REST the second.
CMC_API_KEY=
CMC_MCP_URL=https://mcp.coinmarketcap.com/mcp
CMC_REST_BASE=https://pro-api.coinmarketcap.com
CMC_X402_BASE=https://pro-api.coinmarketcap.com/x402

# --- Trust Wallet Agent Kit (execution + x402) ---
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=

# --- Agent wallet (the SINGLE registered wallet — all scored trades originate here) ---
# Dedicated hot wallet. Only the week's capital. NEVER commit the real value.
AGENT_PRIVATE_KEY=

# --- x402 payment wallet (USDC on Base — CMC settles on Base) ---
# Can be the same key as AGENT_PRIVATE_KEY or a separate funded one.
X402_PRIVATE_KEY=

# --- BSC RPC (use a paid/keyed endpoint for the live week; public RPCs rate-limit) ---
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_CHAIN_ID=56

# --- Ops ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Mode ---
# dev | live  (dev = mainnet-tiny amounts; TWAK testnet is undocumented)
SENTINEL_MODE=dev
